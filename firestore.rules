rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safe catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Application allows anonymous auth with a shared password
    function isSignedIn() { return true; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidCompetitor(data) {
      return data.keys().hasAll(['bib', 'firstName', 'lastName', 'category', 'epreuve', 'chipNumber']) &&
             data.bib is string && data.bib.size() <= 100 &&
             data.firstName is string && data.firstName.size() <= 100 &&
             data.lastName is string && data.lastName.size() <= 100 &&
             data.category is string && data.category.size() <= 100 &&
             data.epreuve is string && data.epreuve.size() <= 100 &&
             data.chipNumber is string && data.chipNumber.size() <= 100 &&
             ( !('id' in data) || (data.id is string && data.id.size() <= 128) ) &&
             ( !('epreuveId' in data) || (data.epreuveId is string && data.epreuveId.size() <= 128) ) &&
             ( !('club' in data) || (data.club is string && data.club.size() <= 200) );
    }

    match /competitors/{competitorId} {
      allow read, write: if isSignedIn();
    }

    match /epreuves/{epreuveId} {
       allow read, write: if isSignedIn();
    }

    match /logs/{logId} {
       allow read, write: if isSignedIn();
    }
  }
}
